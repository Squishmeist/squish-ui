{
  "name": "squishui-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@squishui/docs",
    "build": "turbo run build",
    "start": "turbo run start --filter=@squishui/docs",
    "clean": "git clean -xdf node_modules",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=@squishui/web",
    "test:mobile": "turbo run test --filter=@squishui/mobile"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  }
}
